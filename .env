# ═══════════════════════════════════════════════════════
#  BloodLink — Environment Configuration
#  Copy this file to your backend/ folder as  .env
#  NEVER commit .env to Git — add it to .gitignore
# ═══════════════════════════════════════════════════════

# ── SERVER ──────────────────────────────────────────────
PORT=5000
HOST=0.0.0.0

# ── JWT SECRET (REQUIRED) ───────────────────────────────
# Generate a strong secret:  node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
# Must be at least 32 characters.
JWT_SECRET=bloodlink_jwt_donation_app_secret_key_hospital_donor

# ── MONGODB (REQUIRED) ──────────────────────────────────
# Option A — MongoDB Atlas (cloud, free tier):
#   1. Go to https://cloud.mongodb.com  →  Create free cluster
#   2. Database Access → Add user  (username + password)
#   3. Network Access → Allow 0.0.0.0/0
#   4. Connect → Drivers → copy connection string
#   Replace <username>, <password>, <dbname> below:
# MONGO_URI=mongodb+srv://bloodlink:bloodlink%40@cluster0.xxxxxx.mongodb.net/bloodlink?retryWrites=true&w=majority

# Option B — Local MongoDB:
MONGO_URI=mongodb://localhost:27017/bloodlink



# ── API KEY FOR ROUTE PROTECTION (REQUIRED) ─────────────
# This key must be sent in the  X-API-Key  header for
# all admin/sensitive API calls from your frontend.
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
API_KEY=7c3e525e1fb153a90579cd66f70d324ed04dea5203fb52313a25ff4324e4dccf

# ── CORS — Allowed frontend origins ─────────────────────
# Comma-separated list of URLs that are allowed to call your API.
# For local dev: http://localhost:5500,http://127.0.0.1:5500
# For production: https://yourdomain.com
ALLOWED_ORIGINS=http://127.0.0.1:5500,http://localhost:5500,http://127.0.0.1:5000,http://localhost:5000,http://127.0.0.1:5005,http://localhost:5005

# ── FAST2SMS — OTP + DONOR ALERT SMS ───────────────────────
# Fast2SMS sends OTP and blood-request alerts to mobile numbers.
#
# Setup (5 minutes):
#   1. Go to https://www.fast2sms.com → Sign up free (get ₹50 credit)
#   2. Dashboard → Dev API → copy your API Key
#   3. Paste it below
#
# Notes:
#   - Uses the "Quick SMS" (q) route — no DLT template required for testing.
#   - For production transactional SMS, register a DLT template on Fast2SMS.
#   - Free ₹50 credit gives ~100–200 SMS. Recharge as needed.
#   - Only Indian (10-digit) mobile numbers are supported.
#
FAST2SMS_API_KEY=OiSPfNxMmIWzhZHrja5Ttsc7461GAk8VupwnvDR02y3CUB9KdFjH7hySJzeMYkDCtVZgAf5mnLBcx4o6

# ── GEMINI AI ───────────────────────
GEMINI_API_KEY=AIzaSyBrP6aMRAXLeaBX8qmVbr-4sENiUEnCd28
